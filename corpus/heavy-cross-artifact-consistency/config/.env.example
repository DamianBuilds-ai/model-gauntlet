# Northwind Orders - example environment file (Globex)
# Copy to .env and fill in. These are infrastructure/runtime variables only.
# NOTE: this file holds infrastructure variables only. It is listed in the change
# request for completeness but contains no customer identity field, so CR-4471
# leaves it unchanged. Do not invent a customer variable here.

DATABASE_URL=postgres://localhost:5432/northwind_orders
HTTP_PORT=8080
LOG_LEVEL=info
METRICS_ENABLED=true
REQUEST_TIMEOUT_SECONDS=30
ORDER_REF_PREFIX=ord_
