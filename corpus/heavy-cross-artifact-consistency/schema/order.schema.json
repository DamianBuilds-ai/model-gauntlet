{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://globex.example/schemas/order.schema.json",
  "title": "Order",
  "description": "An order in Northwind Orders. The customer_ref property is a string today; CR-4471 renames it to customer_id and retypes it to integer.",
  "type": "object",
  "required": ["order_ref", "customer_ref", "status", "currency"],
  "additionalProperties": false,
  "properties": {
    "order_ref": {
      "type": "string",
      "description": "Human-facing order reference. Stays a string. NOT the target of CR-4471.",
      "pattern": "^ord_\\d{4}$"
    },
    "customer_ref": {
      "type": "string",
      "description": "Customer identity. CR-4471: rename to customer_id, retype to integer, drop the cust_ pattern.",
      "pattern": "^cust_\\d{5}$",
      "examples": ["cust_00417", "cust_09900"]
    },
    "status": {
      "type": "string",
      "enum": ["draft", "placed", "fulfilled", "cancelled"]
    },
    "currency": {
      "type": "string",
      "minLength": 3,
      "maxLength": 3
    },
    "line_items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["sku", "quantity", "unit_price_minor"],
        "properties": {
          "sku": { "type": "string" },
          "quantity": { "type": "integer", "minimum": 1 },
          "unit_price_minor": { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
